import React, { useState, useEffect } from 'react'

const NavigationBar = ({ onFilterChange, casinoData }) => {
  const [filters, setFilters] = useState({
    zone: 'all',
    machineType: 'all',
    gameType: 'all',
    occupancy: 'all',
    dayOfWeek: 'all',
    hourOfDay: 'all'
  })

  const [zones, setZones] = useState([])
  const [machineTypes, setMachineTypes] = useState([])
  const [gameTypes, setGameTypes] = useState([])
  const [daysOfWeek] = useState(['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'])
  // Create hours array starting from 6AM (6) to 5AM (5) next day
  const [hoursOfDay] = useState([...Array.from({length: 18}, (_, i) => i + 6), ...Array.from({length: 6}, (_, i) => i)])

  useEffect(() => {
    if (casinoData && casinoData.length > 0) {
      const uniqueZones = [...new Set(casinoData.map(item => item.zone))]
      const uniqueMachineTypes = [...new Set(casinoData.map(item => item.machine_type))]
      const uniqueGameTypes = [...new Set(casinoData.map(item => item.game_type))]
      
      setZones(uniqueZones.sort())
      setMachineTypes(uniqueMachineTypes.sort())
      setGameTypes(uniqueGameTypes.sort())
    }
  }, [casinoData])

  const handleFilterChange = (filterType, value) => {
    const newFilters = { ...filters, [filterType]: value }
    setFilters(newFilters)
    onFilterChange(newFilters)
  }

  const formatHourDisplay = (hour) => {
    if (hour === 0) return '12:00 AM'
    if (hour < 12) return `${hour}:00 AM`
    if (hour === 12) return '12:00 PM'
    return `${hour - 12}:00 PM`
  }

  return (
    <nav 
      className="fixed top-0 left-0 right-0 z-50 bg-gradient-to-r from-slate-900 via-slate-800 to-slate-900 backdrop-blur-sm border-b border-slate-700 shadow-lg"
      style={{
        position: 'fixed',
        top: 0,
        left: 0,
        right: 0,
        zIndex: 1000,
        background: 'linear-gradient(to right, #0f172a, #1e293b, #0f172a)',
        borderBottom: '1px solid #374151',
        boxShadow: '0 4px 6px -1px rgba(0, 0, 0, 0.1)'
      }}
    >
      <div 
        className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"
        style={{ maxWidth: '80rem', margin: '0 auto', padding: '0 1rem' }}
      >
        <div 
          className="flex items-center justify-between h-20"
          style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', height: '5rem' }}
        >
          {/* Logo/Title */}
          <div className="flex-shrink-0" style={{ flexShrink: 0 }}>
            <h1 
              className="text-2xl font-bold text-white flex items-center gap-3"
              style={{ fontSize: '1.5rem', fontWeight: 'bold', color: 'white', display: 'flex', alignItems: 'center', gap: '0.75rem' }}
            >
              <div 
                className="w-8 h-8 bg-gradient-to-br from-blue-500 to-purple-600 rounded-lg flex items-center justify-center"
                style={{ width: '2rem', height: '2rem', background: 'linear-gradient(to bottom right, #3b82f6, #8b5cf6)', borderRadius: '0.5rem', display: 'flex', alignItems: 'center', justifyContent: 'center' }}
              >
                <svg className="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm0 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V8zm0 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1v-2z" clipRule="evenodd" />
                </svg>
              </div>
              Casino Floor Map
            </h1>
          </div>

          {/* Filters */}
          <div 
            className="hidden lg:flex items-center space-x-4"
            style={{ display: 'flex', alignItems: 'center', gap: '1rem' }}
          >
            {/* Zone Filter */}
            <div 
              className="flex flex-col space-y-1"
              style={{ display: 'flex', flexDirection: 'column', gap: '0.25rem' }}
            >
              <label 
                htmlFor="zone-filter" 
                className="text-xs font-medium text-slate-300 uppercase tracking-wide"
                style={{ fontSize: '0.75rem', fontWeight: 500, color: '#cbd5e1', textTransform: 'uppercase', letterSpacing: '0.025em' }}
              >
                Zone
              </label>
              <select
                id="zone-filter"
                value={filters.zone}
                onChange={(e) => handleFilterChange('zone', e.target.value)}
                className="bg-slate-700 border border-slate-600 text-white text-sm rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 block px-3 py-2 min-w-[120px] transition-all duration-200 hover:bg-slate-600"
                style={{
                  background: '#374151',
                  border: '1px solid #4b5563',
                  color: 'white',
                  fontSize: '0.875rem',
                  borderRadius: '0.5rem',
                  padding: '0.5rem 0.75rem',
                  minWidth: '120px',
                  outline: 'none'
                }}
              >
                <option value="all">All Zones</option>
                {zones.map(zone => (
                  <option key={zone} value={zone}>{zone}</option>
                ))}
              </select>
            </div>

            {/* Machine Type Filter */}
            <div className="flex flex-col space-y-1">
              <label htmlFor="machine-type-filter" className="text-xs font-medium text-slate-300 uppercase tracking-wide">
                Machine Type
              </label>
              <select
                id="machine-type-filter"
                value={filters.machineType}
                onChange={(e) => handleFilterChange('machineType', e.target.value)}
                className="bg-slate-700 border border-slate-600 text-white text-sm rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 block px-3 py-2 min-w-[140px] transition-all duration-200 hover:bg-slate-600"
              >
                <option value="all">All Types</option>
                {machineTypes.map(type => (
                  <option key={type} value={type}>{type}</option>
                ))}
              </select>
            </div>

            {/* Game Type Filter */}
            <div className="flex flex-col space-y-1">
              <label htmlFor="game-type-filter" className="text-xs font-medium text-slate-300 uppercase tracking-wide">
                Game Type
              </label>
              <select
                id="game-type-filter"
                value={filters.gameType}
                onChange={(e) => handleFilterChange('gameType', e.target.value)}
                className="bg-slate-700 border border-slate-600 text-white text-sm rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 block px-3 py-2 min-w-[120px] transition-all duration-200 hover:bg-slate-600"
              >
                <option value="all">All Games</option>
                {gameTypes.map(type => (
                  <option key={type} value={type}>{type}</option>
                ))}
              </select>
            </div>

            {/* Occupancy Filter */}
            <div className="flex flex-col space-y-1">
              <label htmlFor="occupancy-filter" className="text-xs font-medium text-slate-300 uppercase tracking-wide">
                Occupancy
              </label>
              <select
                id="occupancy-filter"
                value={filters.occupancy}
                onChange={(e) => handleFilterChange('occupancy', e.target.value)}
                className="bg-slate-700 border border-slate-600 text-white text-sm rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 block px-3 py-2 min-w-[130px] transition-all duration-200 hover:bg-slate-600"
              >
                <option value="all">All</option>
                <option value="occupied">🔴 Occupied</option>
                <option value="vacant">⚪ Vacant</option>
              </select>
            </div>

            {/* Day of Week Filter */}
            <div className="flex flex-col space-y-1">
              <label htmlFor="day-filter" className="text-xs font-medium text-slate-300 uppercase tracking-wide">
                Day
              </label>
              <select
                id="day-filter"
                value={filters.dayOfWeek}
                onChange={(e) => handleFilterChange('dayOfWeek', e.target.value)}
                className="bg-slate-700 border border-slate-600 text-white text-sm rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 block px-3 py-2 min-w-[120px] transition-all duration-200 hover:bg-slate-600"
              >
                <option value="all">All Days</option>
                {daysOfWeek.map(day => (
                  <option key={day} value={day}>{day.slice(0, 3)}</option>
                ))}
              </select>
            </div>

            {/* Hour of Day Filter */}
            <div className="flex flex-col space-y-1">
              <label htmlFor="hour-filter" className="text-xs font-medium text-slate-300 uppercase tracking-wide">
                Hour
              </label>
              <select
                id="hour-filter"
                value={filters.hourOfDay}
                onChange={(e) => handleFilterChange('hourOfDay', e.target.value)}
                className="bg-slate-700 border border-slate-600 text-white text-sm rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 block px-3 py-2 min-w-[110px] transition-all duration-200 hover:bg-slate-600"
              >
                <option value="all">All Hours</option>
                {hoursOfDay.map(hour => (
                  <option key={hour} value={hour}>
                    {formatHourDisplay(hour)}
                  </option>
                ))}
              </select>
            </div>

            {/* Clear Filters Button */}
            <div className="flex flex-col justify-end h-full pt-6">
              <button 
                onClick={() => {
                  const defaultFilters = {
                    zone: 'all',
                    machineType: 'all',
                    gameType: 'all',
                    occupancy: 'all',
                    dayOfWeek: 'all',
                    hourOfDay: 'all'
                  }
                  setFilters(defaultFilters)
                  onFilterChange(defaultFilters)
                }}
                className="bg-gradient-to-r from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 transform hover:scale-105 hover:shadow-lg flex items-center gap-2"
              >
                <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
                </svg>
                Clear
              </button>
            </div>
          </div>

          {/* Mobile menu button */}
          <div className="lg:hidden">
            <button className="text-slate-300 hover:text-white p-2">
              <svg className="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>

        {/* Mobile filters (hidden by default) */}
        <div className="lg:hidden bg-slate-800 rounded-lg p-4 mb-4 space-y-4">
          <div className="grid grid-cols-2 gap-4">
            <div className="space-y-2">
              <label className="text-xs font-medium text-slate-300 uppercase tracking-wide">Zone</label>
              <select
                value={filters.zone}
                onChange={(e) => handleFilterChange('zone', e.target.value)}
                className="bg-slate-700 border border-slate-600 text-white text-sm rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 block w-full px-3 py-2"
              >
                <option value="all">All Zones</option>
                {zones.map(zone => (
                  <option key={zone} value={zone}>{zone}</option>
                ))}
              </select>
            </div>

            <div className="space-y-2">
              <label className="text-xs font-medium text-slate-300 uppercase tracking-wide">Machine Type</label>
              <select
                value={filters.machineType}
                onChange={(e) => handleFilterChange('machineType', e.target.value)}
                className="bg-slate-700 border border-slate-600 text-white text-sm rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 block w-full px-3 py-2"
              >
                <option value="all">All Types</option>
                {machineTypes.map(type => (
                  <option key={type} value={type}>{type}</option>
                ))}
              </select>
            </div>

            <div className="space-y-2">
              <label className="text-xs font-medium text-slate-300 uppercase tracking-wide">Game Type</label>
              <select
                value={filters.gameType}
                onChange={(e) => handleFilterChange('gameType', e.target.value)}
                className="bg-slate-700 border border-slate-600 text-white text-sm rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 block w-full px-3 py-2"
              >
                <option value="all">All Games</option>
                {gameTypes.map(type => (
                  <option key={type} value={type}>{type}</option>
                ))}
              </select>
            </div>

            <div className="space-y-2">
              <label className="text-xs font-medium text-slate-300 uppercase tracking-wide">Occupancy</label>
              <select
                value={filters.occupancy}
                onChange={(e) => handleFilterChange('occupancy', e.target.value)}
                className="bg-slate-700 border border-slate-600 text-white text-sm rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 block w-full px-3 py-2"
              >
                <option value="all">All</option>
                <option value="occupied">🔴 Occupied</option>
                <option value="vacant">⚪ Vacant</option>
              </select>
            </div>

            <div className="space-y-2">
              <label className="text-xs font-medium text-slate-300 uppercase tracking-wide">Day</label>
              <select
                value={filters.dayOfWeek}
                onChange={(e) => handleFilterChange('dayOfWeek', e.target.value)}
                className="bg-slate-700 border border-slate-600 text-white text-sm rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 block w-full px-3 py-2"
              >
                <option value="all">All Days</option>
                {daysOfWeek.map(day => (
                  <option key={day} value={day}>{day}</option>
                ))}
              </select>
            </div>

            <div className="space-y-2">
              <label className="text-xs font-medium text-slate-300 uppercase tracking-wide">Hour</label>
              <select
                value={filters.hourOfDay}
                onChange={(e) => handleFilterChange('hourOfDay', e.target.value)}
                className="bg-slate-700 border border-slate-600 text-white text-sm rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 block w-full px-3 py-2"
              >
                <option value="all">All Hours</option>
                {hoursOfDay.map(hour => (
                  <option key={hour} value={hour}>
                    {formatHourDisplay(hour)}
                  </option>
                ))}
              </select>
            </div>
          </div>
          
          <button 
            onClick={() => {
              const defaultFilters = {
                zone: 'all',
                machineType: 'all',
                gameType: 'all',
                occupancy: 'all',
                dayOfWeek: 'all',
                hourOfDay: 'all'
              }
              setFilters(defaultFilters)
              onFilterChange(defaultFilters)
            }}
            className="w-full bg-gradient-to-r from-red-500 to-red-600 hover:from-red-600 hover:to-red-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200"
          >
            Clear All Filters
          </button>
        </div>
      </div>
    </nav>
  )
}

export default NavigationBar